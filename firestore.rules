rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users: read/write own document only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // rooms: anyone can read; writes locked (admin only via server)
    match /rooms/{roomId} {
      allow read:  if true;
      allow write: if false;
    }

    // bookings: guest can read their own; creation via server API (admin SDK) only
    match /bookings/{bookingId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.guestId;
      allow write: if false;
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
